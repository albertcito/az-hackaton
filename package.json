{
  "name": "code",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && node scripts/copy-cesium.mjs",
    "data:setup": "python3 -m venv .venv && .venv/bin/pip install -r requirements.txt",
    "data:materialize": "python3 scripts/materialize_data.py --from-public",
    "data:precompute": ".venv/bin/python -m analytics.precompute --all",
    "data:prepare": "npm run data:setup && npm run data:materialize && npm run data:precompute"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@nuxt/ui": "^4.8.1",
    "cesium": "^1.141.0",
    "fflate": "^0.8.3",
    "npyjs": "^1.1.0",
    "nuxt": "^4.4.6",
    "tailwindcss": "^4.3.0",
    "tz-lookup": "^6.1.25",
    "vite-plugin-static-copy": "^4.1.0",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "zod": "^4.4.3"
  }
}
